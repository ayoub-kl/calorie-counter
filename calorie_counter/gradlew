##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#   Important for running: https://docs.gradle.org/8.2/userguide/gradle_wrapper.html
#
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a link
app_path=$0
while [ -h "$app_path" ]; do
  ls=$(ls -ld "$app_path")
  link=$(printf '%s\n' "$ls" | sed 's/.*-> \(.*\)/\1/')
  case $link in
    /*) app_path=$link ;;
    *) app_path=$(dirname "$app_path")/$link ;;
  esac
done
APP_HOME=$(cd "${app_path%/*}" && pwd -P) || exit 1
APP_NAME=gradle
CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Find java.exe
if [ -n "$JAVA_HOME" ]; then
  JAVACMD="$JAVA_HOME/bin/java"
else
  JAVACMD=java
fi
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum
if [ -e /dev/fd/1 ]; then
  if [ -r /dev/fd/1 ]; then
    test -z "$MAX_FD" && MAX_FD=1
  fi
fi
if [ -z "$MAX_FD" ] || [ "$MAX_FD" != maximum ] && [ "$MAX_FD" != maximum ]; then
  if [ -e /proc/self/fd ]; then
    if [ -r /proc/self/fd ]; then
      test -z "$MAX_FD" && MAX_FD=1024
    fi
  fi
fi
if [ "$MAX_FD" != maximum ] && [ "$MAX_FD" != maximum ]; then
  ulimit -n "$MAX_FD" || exit 1
fi

# Collect all arguments for the java command, stacking in reverse order:
#   * args from the command line
#   * the main class name
#   * -classpath
#   * -D...appname settings
#   * --module-path (only if needed)
#   * DEFAULT_JVM_OPTS, JAVA_OPTS, and GRADLE_OPTS environment variables.
set -- \
    $DEFAULT_JVM_OPTS \
    "-Dorg.gradle.appname=$APP_NAME" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"

exec "$JAVACMD" "$@"
